#: es-football-bypass.php:1530
msgid "Ignore \"blocked\" states whose most recent stateChange in hayahora.futbol is older than this (1-72 hours, default 6). Prevents orphan records from keeping the bypass active indefinitely when a close event was never published."
msgstr ""

#: es-football-bypass.php:1538
msgid "Simple (recommended for clients)"
msgstr ""

#: es-football-bypass.php:1539
msgid "Advanced (show diagnostics, logs and technical details)"
msgstr ""

#: es-football-bypass.php:1540
msgid "Simple mode hides the feed diagnostics panel, the logs tab and the technical console — leaving only the block status and the manual proxy ON/OFF buttons. Logs are still written to disk: switch to Advanced temporarily if you need to diagnose a problem."
msgstr ""

#: es-football-bypass.php:1549
msgid "Send an email to the site admin when the bypass turns on or off automatically"
msgstr ""

#. translators: %s is the admin email address.
#: es-football-bypass.php:1551
#, php-format
msgid "Emails are sent to %s only on actual state changes from the cron (not on manual override). A 2-minute throttle prevents bursts if the feed oscillates."
msgstr ""

#: es-football-bypass.php:1563
msgid "Minimum number of distinct ISPs (providers) with currently blocked IPs needed to consider there is a real mass block (1-20, default 2). Lower values are more sensitive; 1 triggers on any single-ISP glitch. Only applies when the feed publishes ISP information; ignored otherwise."
msgstr ""

#: es-football-bypass.php:1570
msgid "Disable Proxy during football (General=YES), without waiting for this domain detection"
msgstr ""

#: es-football-bypass.php:1571
msgid "IMPORTANT: With this option enabled, the proxy will be automatically disabled when hayahora.futbol indicates active blocks (General=YES), even if your specific domain has not been detected as blocked."
msgstr ""

#: es-football-bypass.php:1572
msgid "Useful to avoid false negatives when you know your site is blocked during football events but IP detection doesn't always work correctly."
msgstr ""

#: es-football-bypass.php:1579
msgid "Save actions to log (cron and manual)"
msgstr ""

#: es-football-bypass.php:1580
msgid "Logs are stored in the uploads directory, protected with .htaccess, and displayed in the Logs tab."
msgstr ""

