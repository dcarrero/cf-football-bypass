msgid "Send an email when the bypass turns on or off automatically"
msgstr ""

#: es-football-bypass.php:1605
msgid "Emails are sent only on actual state changes from the cron (not on manual override). A 2-minute throttle prevents bursts if the feed oscillates."
msgstr ""

