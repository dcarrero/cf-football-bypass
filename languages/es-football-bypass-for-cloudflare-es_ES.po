#. Plugin Name of the plugin
#: es-football-bypass.php
msgid "ES Football Bypass for Cloudflare"
msgstr "ES Football Bypass for Cloudflare"

#. Plugin URI of the plugin
#: es-football-bypass.php
msgid "https://github.com/dcarrero/cf-football-bypass"
msgstr "https://github.com/dcarrero/cf-football-bypass"

#. Description of the plugin
#: es-football-bypass.php
msgid ""
"Operates with Cloudflare to toggle between Proxy (ON/CDN) and DNS Only (OFF) "
"based on IP blocks, with persistent DNS cache and AJAX actions. Separate UI: "
"Operation and Settings."
msgstr ""
"Opera con Cloudflare para alternar Proxy (ON/CDN) y DNS Only (OFF) según "
"bloqueos, con caché persistente de registros y acciones AJAX. UI separada: "
"Operación y Configuración."

#. Author of the plugin
#: es-football-bypass.php
msgid "David Carrero Fernandez-Baillo"
msgstr "David Carrero Fernandez-Baillo"

#. Author URI of the plugin
#: es-football-bypass.php
msgid "https://carrero.es"
msgstr "https://carrero.es"

