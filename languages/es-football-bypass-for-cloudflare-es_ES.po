msgstr "Error de conexión:"

#: es-football-bypass.php:1363
msgid ""
"Saving automatically verifies the connection and permissions (does not alter "
"your DNS cache)."
msgstr ""
"Al guardar se verifica automáticamente la conexión y permisos (no altera tu "
"caché de DNS)."

#: es-football-bypass.php:1373
msgid "Console:"
msgstr "Consola:"

#: es-football-bypass.php:1374
