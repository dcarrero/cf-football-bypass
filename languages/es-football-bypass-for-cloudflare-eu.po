msgstr "Proxy OFF behartu futbolean"

#: es-football-bypass.php:1206
msgid "Check interval (minutes)"
msgstr "Egiaztapen tartea (minutuak)"

#: es-football-bypass.php:1207
msgid "Cooldown after disabling Cloudflare (min)"
msgstr "Cloudflare desaktibatu ondorengo tartea (min)"

#: es-football-bypass.php:1208
msgid "Minimum ISPs with blocks"
msgstr "Blokeoak dituzten gutxieneko ISP kopurua"

#: es-football-bypass.php:1209
msgid "DNS records to manage (loaded in Operation)"
msgstr "Kudeatzeko DNS erregistroak (Eragiketan kargatzen dira)"

#: es-football-bypass.php:1212
msgid "Email notifications"
msgstr "Email jakinarazpenak"

#: es-football-bypass.php:1213
msgid "Enable email notifications"
msgstr "Email jakinarazpenak gaitu"

#: es-football-bypass.php:1214
msgid "Notifications recipient"
msgstr "Jakinarazpenen hartzailea"

#: es-football-bypass.php:1217
msgid "Uninstall"
msgstr "Desinstalatzean"

#: es-football-bypass.php:1218
msgid "Delete data on uninstall"
msgstr "Desinstalatzean datuak ezabatu"

#: es-football-bypass.php:1222
msgid "Advanced options"
msgstr "Aukera aurreratuak"

#: es-football-bypass.php:1223
msgid "Staleness threshold (hours)"
msgstr "Zaharkitze-atalasea (orduak)"

#: es-football-bypass.php:1224
msgid "Action logging"
msgstr "Ekintzen erregistroa"

#: es-football-bypass.php:1225
